{
  "name": "@vaivae/medusa",
  "version": "0.0.0",
  "private": true,
  "description": "vaïvae Medusa v2 commerce backend — runs on Medusa Cloud, serves api.vaivae.com.",
  "license": "UNLICENSED",
  "engines": {
    "node": "24.15.0"
  },
  "scripts": {
    "dev": "medusa develop",
    "build": "medusa build",
    "start": "medusa start",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "test": "pnpm --dir ../.. exec vitest run --project @vaivae/medusa",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "db:migrate": "medusa db:migrate",
    "db:generate": "medusa db:generate",
    "db:rollback": "medusa db:rollback",
    "db:setup": "medusa db:setup",
    "db:seed": "medusa exec ./src/scripts/seed.ts",
    "user:create": "medusa user",
    "clean": "rm -rf .medusa dist .turbo node_modules"
  },
  "dependencies": {
    "@medusajs/medusa": "catalog:",
    "@medusajs/framework": "catalog:",
    "@medusajs/types": "catalog:",
    "@medusajs/utils": "catalog:",
    "@medusajs/payment-stripe": "catalog:",
    "@medusajs/analytics-posthog": "catalog:",
    "@medusajs/loyalty-plugin": "catalog:",
    "@sentry/node": "10.52.0",
    "@alphabite/medusa-wishlist": "0.5.9",
    "@sanity/client": "7.22.0",
    "react": "catalog:",
    "react-dom": "catalog:",
    "klaviyo-api": "22.0.1",
    "posthog-node": "5.33.4",
    "shippo": "2.18.0",
    "@mux/mux-node": "14.0.1",
    "jose": "6.2.3",
    "pino": "10.3.1",
    "awilix": "8.0.1"
  },
  "devDependencies": {
    "typescript": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@medusajs/cli": "catalog:",
    "@medusajs/admin-vite-plugin": "catalog:",
    "@medusajs/admin-shared": "catalog:",
    "@medusajs/admin-sdk": "catalog:",
    "@medusajs/dashboard": "catalog:",
    "@medusajs/draft-order": "catalog:",
    "eslint": "9.39.4",
    "eslint-config-prettier": "10.1.8",
    "@typescript-eslint/parser": "8.59.2",
    "@typescript-eslint/eslint-plugin": "8.59.2",
    "tsx": "4.21.0",
    "ts-node": "10.9.2",
    "tsconfig-paths": "4.2.0",
    "pino-pretty": "13.1.3"
  }
}
