# Local development only. Medusa Cloud injects DATABASE_URL and REDIS_URL per environment.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/vaivae_medusa

# Optional locally. Medusa Cloud Launch+ auto-configures Redis-backed infra modules.
REDIS_URL=redis://localhost:6379
ENABLE_EXPLICIT_REDIS_MODULES=false
MEDUSA_WORKER_MODE=shared
LOG_LEVEL=info

# Strong random auth secrets. Generate unique values per environment.
JWT_SECRET=<generate-with-openssl-rand-base64-32>
COOKIE_SECRET=<generate-with-openssl-rand-base64-32>

# CORS and public URLs. Use exact origins in production; no wildcards.
STORE_CORS=http://localhost:3000
ADMIN_CORS=http://localhost:9000
AUTH_CORS=http://localhost:3000
MEDUSA_BACKEND_URL=http://localhost:9000
MEDUSA_STOREFRONT_URL=http://localhost:3000

# Stripe payment provider and webhook signing secret.
STRIPE_API_KEY=<stripe-secret-key>
STRIPE_WEBHOOK_SECRET=<stripe-webhook-secret>

# Klaviyo marketing sync. Private values are server-only.
KLAVIYO_PRIVATE_API_KEY=<klaviyo-private-api-key>
KLAVIYO_PUBLIC_API_KEY=<klaviyo-public-api-key>

# Server-side PostHog events through the Medusa analytics plugin.
POSTHOG_API_KEY=<posthog-server-api-key>
POSTHOG_HOST=https://us.i.posthog.com

# Shippo label purchase and tracking updates.
SHIPPO_API_KEY=<shippo-api-key>
SHIPPING_LABEL_AUTOPURCHASE=false

# Mux server-side video operations.
MUX_TOKEN_ID=<mux-token-id>
MUX_TOKEN_SECRET=<mux-token-secret>

# Sanity write access for Medusa-to-Sanity sync subscribers.
SANITY_PROJECT_ID=<sanity-project-id>
SANITY_DATASET=development
SANITY_API_VERSION=2026-03-01
SANITY_API_TOKEN=<sanity-write-token>
SANITY_STUDIO_URL=http://localhost:3000/studio

# Shared secret for Medusa-to-storefront revalidation webhooks.
MEDUSA_REVALIDATE_SECRET=<shared-revalidation-secret>
