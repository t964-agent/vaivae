{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "globalDependencies": ["**/.env", "**/.env.*local", "tsconfig.base.json", ".npmrc"],
  "globalEnv": ["NODE_ENV", "VERCEL", "VERCEL_ENV", "CI"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", ".medusa/server/**", "dist/**", "build/**"],
      "env": [
        "NEXT_PUBLIC_*",
        "SANITY_*",
        "NEXT_PUBLIC_SANITY_*",
        "MEDUSA_*",
        "STRIPE_*",
        "DATABASE_URL",
        "REDIS_URL",
        "JWT_SECRET",
        "COOKIE_SECRET",
        "STORE_CORS",
        "ADMIN_CORS",
        "AUTH_CORS"
      ]
    },
    "dev": {
      "persistent": true,
      "cache": false,
      "env": [
        "NEXT_PUBLIC_*",
        "SANITY_*",
        "NEXT_PUBLIC_SANITY_*",
        "MEDUSA_*",
        "STRIPE_*",
        "DATABASE_URL",
        "REDIS_URL",
        "JWT_SECRET",
        "COOKIE_SECRET",
        "STORE_CORS",
        "ADMIN_CORS",
        "AUTH_CORS"
      ]
    },
    "start": {
      "dependsOn": ["build"],
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    },
    "test:e2e": {
      "dependsOn": ["^build"],
      "outputs": ["playwright-report/**", "test-results/**"]
    },
    "clean": {
      "cache": false
    }
  }
}
