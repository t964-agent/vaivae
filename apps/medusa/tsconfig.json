{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2024",
    "lib": ["ES2024"],
    "module": "Node16",
    "moduleResolution": "Node16",
    "outDir": "./dist",
    "rootDir": ".",
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "noEmit": false,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "incremental": true,
    "paths": {
      "@/*": ["./src/*"],
      "@/modules/*": ["./src/modules/*"],
      "@/subscribers/*": ["./src/subscribers/*"],
      "@/workflows/*": ["./src/workflows/*"],
      "@/api/*": ["./src/api/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "instrumentation.ts", "medusa-config.ts"],
  "exclude": ["node_modules", "dist", ".medusa", "**/*.test.ts", "**/*.spec.ts"]
}
