{
  "name": "@vaivae/medusa",
  "version": "0.0.0",
  "private": true,
  "description": "vaïvae Medusa v2 commerce backend — runs on Medusa Cloud, serves api.vaivae.com.",
  "license": "UNLICENSED",
  "engines": {
    "node": "24.15.0"
  },
  "scripts": {
    "patch:medusa-promotion": "node -e \"const fs=require('node:fs'); const script=fs.existsSync('./src/scripts/patch-medusa-promotion.js') ? './src/scripts/patch-medusa-promotion.js' : './src/scripts/patch-medusa-promotion.cjs'; require(script)\"",
    "predev": "pnpm run patch:medusa-promotion",
    "dev": "medusa develop",
    "prebuild": "pnpm run patch:medusa-promotion",
    "build": "node -r ts-node/register -r tsconfig-paths/register -e \"process.argv.push('build'); require('./medusa-config')\" && rm -rf .medusa/server && medusa build && test -f .medusa/server/package.json && test -f .medusa/server/medusa-config.js",
    "prestart": "pnpm run patch:medusa-promotion",
    "start": "medusa start",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc --noEmit && tsc --project tsconfig.admin.json --noEmit",
    "test": "pnpm --dir ../.. exec vitest run --project @vaivae/medusa",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "db:migrate": "medusa db:migrate",
    "db:generate": "medusa db:generate",
    "db:rollback": "medusa db:rollback",
    "db:setup": "medusa db:setup",
    "db:seed": "medusa exec ./src/scripts/seed.ts",
    "user:create": "medusa user",
    "clean": "rm -rf .medusa dist .turbo node_modules"
  },
  "dependencies": {
    "@medusajs/medusa": "2.14.2",
    "@medusajs/framework": "2.14.2",
    "@medusajs/types": "2.14.2",
    "@medusajs/utils": "2.14.2",
    "@medusajs/cli": "2.14.2",
    "@medusajs/admin-vite-plugin": "2.14.2",
    "@medusajs/admin-shared": "2.14.2",
    "@medusajs/admin-sdk": "2.14.2",
    "@medusajs/dashboard": "2.14.2",
    "@medusajs/js-sdk": "2.14.2",
    "@medusajs/ui": "4.1.9",
    "@medusajs/draft-order": "2.14.2",
    "@medusajs/payment-stripe": "2.14.2",
    "@medusajs/analytics-posthog": "2.14.2",
    "@medusajs/loyalty-plugin": "2.14.2",
    "@sentry/node": "10.52.0",
    "@alphabite/medusa-wishlist": "0.5.9",
    "@sanity/client": "7.22.0",
    "@tanstack/react-query": "5.64.2",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "klaviyo-api": "22.0.1",
    "posthog-node": "5.33.4",
    "shippo": "2.18.0",
    "@mux/mux-node": "14.0.1",
    "jose": "6.2.3",
    "pino": "10.3.1",
    "awilix": "8.0.1"
  },
  "devDependencies": {
    "typescript": "6.0.3",
    "@types/node": "24.12.3",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.4",
    "eslint-config-prettier": "10.1.8",
    "@typescript-eslint/parser": "8.59.2",
    "@typescript-eslint/eslint-plugin": "8.59.2",
    "tsx": "4.21.0",
    "ts-node": "10.9.2",
    "tsconfig-paths": "4.2.0",
    "pino-pretty": "13.1.3"
  }
}
