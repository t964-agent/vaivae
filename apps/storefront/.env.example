# Public origin for absolute URLs, canonical metadata, and webhook callbacks.
NEXT_PUBLIC_BASE_URL=https://vaivae.com

# Medusa Store API. Use the local backend in development.
NEXT_PUBLIC_MEDUSA_BACKEND_URL=http://localhost:9000

# Browser-safe Medusa publishable key scoped to the storefront sales channel.
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=<medusa-publishable-key>

# Server-side Medusa region id used while Phase 1 has a single US/USD market.
REGION_ID=<medusa-region-id>

# Shared secret for Medusa-to-storefront revalidation webhooks.
MEDUSA_REVALIDATE_SECRET=<shared-revalidation-secret>

# Sanity project id for the embedded Studio and Content Lake reads.
NEXT_PUBLIC_SANITY_PROJECT_ID=<sanity-project-id>

# Sanity dataset. Defaults in code to development outside production, production in production.
NEXT_PUBLIC_SANITY_DATASET=development

# Server-only Sanity read token for draft/private reads. Optional until draft mode is wired.
SANITY_API_READ_TOKEN=<sanity-read-token>

# Shared secret for Sanity webhook-triggered revalidation.
SANITY_REVALIDATE_SECRET=<sanity-revalidate-secret>

# Optional Sanity-hosted Studio hostname for `sanity deploy`; embedded /studio is primary.
SANITY_STUDIO_HOSTNAME=<sanity-studio-hostname>

# Browser-safe Stripe publishable key. Secret keys only live in Medusa.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=<stripe-publishable-key>

# Consent-gated PostHog browser analytics.
NEXT_PUBLIC_POSTHOG_KEY=<posthog-project-key>
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Consent-gated Google Tag Manager container id.
NEXT_PUBLIC_GTM_ID=<gtm-container-id>

# Termly CMP website UUID for global GDPR-equivalent consent posture.
NEXT_PUBLIC_TERMLY_WEBSITE_UUID=<termly-website-uuid>

# Mux environment key for public video playback analytics.
NEXT_PUBLIC_MUX_ENV_KEY=<mux-environment-key>

# Klaviyo onsite tracking public key. Loading remains consent-gated.
NEXT_PUBLIC_KLAVIYO_PUBLIC_API_KEY=<klaviyo-public-api-key>

# Sentry runtime DSNs and source-map upload credentials.
SENTRY_DSN=<sentry-server-dsn>
NEXT_PUBLIC_SENTRY_DSN=<sentry-browser-dsn>
SENTRY_AUTH_TOKEN=<sentry-auth-token>
SENTRY_ORG=<sentry-org-slug>
SENTRY_PROJECT=vaivae-storefront
