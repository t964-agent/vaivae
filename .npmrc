# pnpm configuration for vaïvae monorepo

# Hoist only what tooling like ESLint/Prettier/TS expects to resolve at the workspace root.
# Everything else stays workspace-local for stricter dependency boundaries.
public-hoist-pattern[]=*types*
public-hoist-pattern[]=*eslint*
public-hoist-pattern[]=*prettier*
public-hoist-pattern[]=*tailwindcss*

# Refuse to install if the lockfile is out of sync with package.json — protects CI from drift.
strict-peer-dependencies=false
auto-install-peers=true

# Use pnpm's content-addressable store for the cleanest disk usage.
node-linker=isolated

# Keep the engines field enforced — Node 24 is required for Medusa Cloud parity and Sanity v5.
engine-strict=true

# Faster CI installs.
prefer-frozen-lockfile=true

# Log dependency upgrades clearly.
loglevel=info

# Save exact versions only — `^` and `~` are forbidden by our pinning policy.
save-exact=true
save-prefix=
