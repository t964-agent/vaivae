# ─────────────────────────────────────────────────────────────────────────────
# Dependencies
# ─────────────────────────────────────────────────────────────────────────────
node_modules/
.pnpm-store/

# ─────────────────────────────────────────────────────────────────────────────
# Build output
# ─────────────────────────────────────────────────────────────────────────────
.next/
.medusa/
dist/
build/
out/
.turbo/
*.tsbuildinfo

# Sanity (Studio build artifacts when run locally)
.sanity/

# ─────────────────────────────────────────────────────────────────────────────
# Environment files — never commit secrets
# ─────────────────────────────────────────────────────────────────────────────
.env
.env.*
!.env.example
!.env.*.example

# ─────────────────────────────────────────────────────────────────────────────
# Test / coverage
# ─────────────────────────────────────────────────────────────────────────────
coverage/
.nyc_output/
playwright-report/
test-results/
playwright/.cache/

# ─────────────────────────────────────────────────────────────────────────────
# Editor / OS
# ─────────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
*.swp
*.swo

# VS Code: keep shared settings, ignore personal
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json

# ─────────────────────────────────────────────────────────────────────────────
# Vercel / deployment
# ─────────────────────────────────────────────────────────────────────────────
.vercel/

# ─────────────────────────────────────────────────────────────────────────────
# Logs
# ─────────────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ─────────────────────────────────────────────────────────────────────────────
# Caches
# ─────────────────────────────────────────────────────────────────────────────
.cache/
.eslintcache
.stylelintcache
.parcel-cache/

# ─────────────────────────────────────────────────────────────────────────────
# Sentry
# ─────────────────────────────────────────────────────────────────────────────
.sentryclirc

# ─────────────────────────────────────────────────────────────────────────────
# Local AI agent / IDE state (do not commit personal session state)
# ─────────────────────────────────────────────────────────────────────────────
.claude/
.agents/
skills-lock.json
.cursor/cache/
.aider*

# ─────────────────────────────────────────────────────────────────────────────
# Misc
# ─────────────────────────────────────────────────────────────────────────────
*.pid
*.seed
*.pid.lock
.pnp.*
.vercel
